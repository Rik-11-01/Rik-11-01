//Insertion Sort:-
#include<iostream>
using namespace std;
void selectionSort(int  arr[], int n)
{   
    for(int i = 1; i < n; i++ ) {
        int temp=arr[i];
        int j=i-1;
        for(j; j>=0; j--) {
            //shift
            if(arr[j] > temp){ 
                arr[j+1]=arr[j];
            }else{
                break;
            }
        }
        arr[j+1]=temp;
    }
}

int main(){
    int n=5;
    int arr[]={3,5,6,8,9};
    selectionSort(arr,5);
    for(int i=0;i<n;i++){
        cout<<arr[i]<<"  ";
    }
    return 0;
}
//Buble sort:
#include<iostream>
using namespace std;
void BubbleSort(int  arr[], int n)
{   
    for(int i = 1; i < n; i++ ) {
        
        for(int j=0; j<n-i-1; j++) {
            //swap
            if(arr[j]>arr[j+1]){
                int temp=arr[j];
                arr[j]=arr[j+1];
                arr[j+1]=temp;
            }
        }
    }
}

int main(){
    int n=5;
    int arr[]={3,5,6,8,9};
    BubbleSort(arr,5);
    for(int i=0;i<n;i++){
        cout<<arr[i]<<"  ";
    }
    return 0;
}
//selection sort:-
#include<iostream>
using namespace std;
void SelectionSort(int  arr[], int n)
{   
    for(int i = 0; i < n-1; i++ ) {
        int minindex=i;
        for(int j=i+1; j<n; j++) {
            //swap
            if(arr[minindex]>arr[j]){
               minindex=j;
            }
        }
        int temp=arr[i];
        arr[i]=arr[minindex];
        arr[minindex]=temp;
    }
}

int main(){
    int n=5;
    int arr[]={3,5,6,8,9};
    SelectionSort(arr,5);
    for(int i=0;i<n;i++){
        cout<<arr[i]<<"  ";
    }
    return 0;
}
//Quick sort:-
#include <bits/stdc++.h>
using namespace std;
 int arr[] = {10, 7, 8, 9, 1, 5, 37, 89, 28, 39}; 
int partition(int a[], int l, int h){
    int i = l, j = h;
    int pivot = a[l];
    while (i<j) {
            while (a[i] <= pivot)
                i++;
            while (a[j] > pivot)
                j--;
            if (i<j){
                int temp=arr[i];
                arr[i]=arr[j];
                arr[j]=temp;
            }
    }
        int temp=arr[j];
        arr[j]=arr[l];
        arr[l]=temp;
    return j;
    
}

void QuickSort(int a[], int l, int h){
    if(l<h){
        int pivot = partition(a, l, h);
        QuickSort(a, l, pivot-1);
        QuickSort(a, pivot + 1, h);
    }
}

