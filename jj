//Insertion Sort:-
#include<iostream>
using namespace std;
void selectionSort(int  arr[], int n)
{   
    for(int i = 1; i < n; i++ ) {
        int temp=arr[i];
        int j=i-1;
        for(j; j>=0; j--) {
            //shift
            if(arr[j] > temp){ 
                arr[j+1]=arr[j];
            }else{
                break;
            }
        }
        arr[j+1]=temp;
    }
}

int main(){
    int n=5;
    int arr[]={3,5,6,8,9};
    selectionSort(arr,5);
    for(int i=0;i<n;i++){
        cout<<arr[i]<<"  ";
    }
    return 0;
}

